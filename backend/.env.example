# amoCRM integration (from amoМаркет → Создать интеграцию)
CLIENT_ID=
CLIENT_SECRET=
REDIRECT_URI=https://your-domain.com/auth/callback

# Same origin as the deployed app (the widget iframe). Comma-separated for several.
CORS_ORIGIN=https://your-domain.com

# Server
PORT=3000
# Max concurrent memory-heavy scans (others queue).
JOB_CONCURRENCY=3

# Auth mode:
#   dev  → API works WITHOUT a widget key (open the frontend directly for testing)
#   prod → widget key required on every request
APP_ENV=prod
# Optional: account used by keyless dev mode (defaults to the first account).
DEV_SUBDOMAIN=

# PostgreSQL
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
