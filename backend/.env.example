# =============================================================================
# Two ways to use this file:
#   1. Local dev: copy to `.env`, fill everything in; dotenv reads it.
#   2. Production (Dokploy + Infisical): do NOT ship a `.env`. The container CMD
#      runs `infisical run -- node dist/server.js`, so every app secret
#      (CLIENT_ID, CLIENT_SECRET, JWT/DB/…) is pulled from Infisical at runtime.
#      Only the INFISICAL_* bootstrap block is given to the container (as Dokploy
#      env vars) and the host's /usr/bin/infisical is bind-mounted in.
# =============================================================================

# --- Infisical bootstrap (production / Dokploy only) -------------------------
INFISICAL_TOKEN=
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=prod
INFISICAL_API_URL=https://infisical.upsoft.app
INFISICAL_DISABLE_LOGGING=true
INFISICAL_LOG_LEVEL=fatal

# --- App secrets (managed inside Infisical in prod; used directly for local dev) ---

# amoCRM integration (from amoМаркет → Создать интеграцию)
CLIENT_ID=
CLIENT_SECRET=
REDIRECT_URI=https://your-domain.com/auth/callback

# Same origin as the deployed app (the widget iframe). Comma-separated for several.
CORS_ORIGIN=https://your-domain.com

# Server
PORT=3000
# Max concurrent memory-heavy scans (others queue).
JOB_CONCURRENCY=3

# Auth mode:
#   dev  → API works WITHOUT a widget key (open the frontend directly for testing)
#   prod → widget key required on every request
APP_ENV=prod
# Optional: account used by keyless dev mode (defaults to the first account).
DEV_SUBDOMAIN=

# PostgreSQL
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
